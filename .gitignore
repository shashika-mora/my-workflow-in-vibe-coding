# --- Polyglot Universal Gitignore ---

# > OS Junk
.DS_Store
Thumbs.db
*.log

# > Node.js / Web
node_modules/
dist/
build/
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/

# > Python
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env/
*.egg-info/
.coverage
htmlcov/
dist/
build/
*.spec

# > Java
*.class
*.jar
*.war
*.ear
target/
.gradle/
build/

# > C++ / C
*.o
*.obj
*.exe
*.dll
*.so
*.dylib
*.out

# > IDEs / Editors
.vscode/
.idea/
*.swp
*.swo
